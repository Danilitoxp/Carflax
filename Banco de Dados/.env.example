# Banco de Dados MySQL
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASS=
DB_NAME=
DB_CONN_LIMIT=10
DB_CONNECT_TIMEOUT=10000
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# Porta do servidor
PORT=3001

# Autenticação JWT — gere uma chave longa e aleatória (mín. 32 caracteres)
# Exemplo: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# CORS — origem permitida (URL do frontend em produção)
ALLOWED_ORIGIN=http://localhost:5173

# Empresas para pedidos não faturados (separadas por vírgula)
EMPRESAS_PEDIDOS=001,002,003

# API Citel (ERP externo) — usar HTTPS em produção
CITEL_API_URL_001=
CITEL_API_URL_002=
CITEL_API_URL_003=
CITEL_API_USER=
CITEL_API_PASS=

# Firebase Admin SDK (opcional)
ADMIN_SERVICE_ACCOUNT_JSON=
ADMIN_SECRET=
