{
  "rewrites": [
    { "source": "/api-marketing/(.*)", "destination": "https://marketing-carflax.velbav.easypanel.host/$1" },
    { "source": "/api-campaign/(.*)", "destination": "https://marketing-gestao-de-tempo.velbav.easypanel.host/$1" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api-marketing|api-campaign|api/).*)", "destination": "/index.html" }
  ]
}
